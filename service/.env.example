# Required — HubSpot Forms API submission target.
# Test portal: 246275387 / 65e1f980-56ca-4c25-90a7-ce0289ca608e
# Swap to production values when you cut the production HubSpot portal over.
HUBSPOT_PORTAL_ID=246275387
HUBSPOT_FORM_ID=65e1f980-56ca-4c25-90a7-ce0289ca608e

# Required — Resend.
# Get from resend.com → API Keys. Use a per-environment key (Dev/Prod).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
# Must be on a verified domain in Resend. Display-name format is allowed.
RESEND_FROM_EMAIL=Locke Operations <hello@lockeoperations.com>
RESEND_REPLY_TO=hello@lockeoperations.com
# Optional — BCC every send to this address for archival/QA.
# RESEND_BCC=archive@lockeoperations.com

# CORS — comma-separated origins allowed to call the API.
ALLOWED_ORIGINS=https://www.lockeoperations.com,https://lockeoperations.com,https://portal.lockeoperations.com
# Optional regex for preview URLs.
ALLOWED_ORIGIN_REGEX=^https://locke-operations-site(-[a-z0-9-]+)?\.vercel\.app$

# Logging
LOG_LEVEL=INFO


# ===============================================================
# Phase 1 portal: Supabase + Clerk
# ===============================================================

# Required for /api/me and /webhooks/clerk. Use the Transaction pooler URI
# (port 6543) from Supabase dashboard → Connect → Transaction pooler.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Clerk API keys from dashboard.clerk.com → API Keys.
CLERK_APP_ID=app_xxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Clerk frontend API URL — used to fetch JWKS for JWT verification.
# Found in Clerk dashboard → API Keys → Show API URLs.
CLERK_FRONTEND_API_URL=https://your-app.clerk.accounts.dev

# Clerk webhook signing secret — set after creating the webhook endpoint
# in Clerk dashboard pointing at <railway-url>/webhooks/clerk.
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Admin API key for Retool / scripts to call /api/admin/* endpoints.
# Generate with: openssl rand -hex 32
# Used as X-Admin-Key header. Audit actions attribute to ADMIN_API_KEY_USER_EMAIL.
ADMIN_API_KEY=
ADMIN_API_KEY_USER_EMAIL=dan@lockeoperations.com

# Landing URL embedded in Clerk invitation emails. Clerk appends
# `?__clerk_ticket=<ticket>` to this URL; the page must mount Clerk's
# SignUp component to consume the ticket. The post-signup redirect to
# /portal is configured client-side in signup.html (signUpFallbackRedirectUrl).
# Must also be added to Clerk's allowed redirect URLs in the dashboard.
SIGNUP_URL=https://locke-operations-site.vercel.app/signup
