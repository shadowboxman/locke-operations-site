# Required — HubSpot Forms API submission target.
# Test portal: 246275387 / 65e1f980-56ca-4c25-90a7-ce0289ca608e
# Swap to production values when you cut the production HubSpot portal over.
HUBSPOT_PORTAL_ID=246275387
HUBSPOT_FORM_ID=65e1f980-56ca-4c25-90a7-ce0289ca608e

# Required — Resend.
# Get from resend.com → API Keys. Use a per-environment key (Dev/Prod).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
# Must be on a verified domain in Resend. Display-name format is allowed.
RESEND_FROM_EMAIL=Locke Operations <hello@lockeoperations.com>
RESEND_REPLY_TO=hello@lockeoperations.com
# Optional — BCC every send to this address for archival/QA.
# RESEND_BCC=archive@lockeoperations.com

# CORS — comma-separated origins allowed to POST to /api/submit.
ALLOWED_ORIGINS=https://www.lockeoperations.com,https://lockeoperations.com
# Optional regex for preview URLs.
ALLOWED_ORIGIN_REGEX=^https://locke-operations-site(-[a-z0-9-]+)?\.vercel\.app$

# Logging
LOG_LEVEL=INFO
